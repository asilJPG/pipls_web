# ------------------------------------------------------------------------------
# Конфигурация для новой базы iiko и Supabase
# Переименуйте этот файл в .env и заполните необходимые значения
# ------------------------------------------------------------------------------

# 1. Параметры API iiko Server (полный iikoRMS/iikoChain сервер)
IIKO_SERVER=https://your-iiko-server-domain:port
IIKO_LOGIN=api_user_login
IIKO_PASSWORD=api_user_password_plain_text
IIKO_REJECT_UNAUTHORIZED=false

# 2. Параметры iikoWeb (облачный кабинет iikoWeb)
IIKO_WEB_URL=https://your-organization.iikoweb.ru
IIKO_WEB_LOGIN=iiko_web_login
IIKO_WEB_PASSWORD=iiko_web_password_plain_text

# 3. ID конфигураций iikoWeb (получите из разделов номенклатуры/складов в iikoWeb)
IIKO_CONCEPTION_ID=your-conception-uuid-here
IIKO_CONTAINER_ID=your-container-or-unit-uuid-here

# 4. База данных Supabase (для хранения пользователей, логов и отчетов смен)
# Создайте таблицы в Supabase с помощью файла schema.sql
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-jwt-key

# 5. Безопасность сессий (произвольная строка для генерации токенов сессий)
JWT_SECRET=your-random-long-secret-key-32-or-64-chars

# 6. Дополнительные интеграции (опционально)
# OpenAI / OpenRouter для функций аналитики и расшифровок (если используются)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Telegram-уведомления (Отключены по умолчанию в кодовой базе standalone-версии)
# TG_BOT_TOKEN=
# TG_CHAT_ID=
